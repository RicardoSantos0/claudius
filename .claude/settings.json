{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./skills/notebooklm/data/browser_state/**)",
      "Read(./skills/notebooklm/data/auth_info.json)",
      "Read(./mas/data/**)",
      "Read(./mas/projects/**)",
      "Read(./.git/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)"
    ],
    "allow": ["Bash(*)", "Read(*)", "Write(*)", "Edit(*)", "Glob(*)", "Grep(*)"]
  }

}
